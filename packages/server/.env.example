# 环境配置
NODE_ENV=development
APP_NAME=account-server
PORT=3000
API_PREFIX=api/v1
APP_ORIGIN=http://localhost:3001

# 日志配置
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_IGNORED_PATHS=/health,/healthz,/metrics,/favicon.ico

# Database
DATABASE_URL=postgresql://admin:admin@localhost:5432/account?schema=public
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=account

# JWT
JWT_ACCESS_SECRET=replace-with-a-strong-secret
JWT_REFRESH_SECRET=replace-with-a-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=account

# LLM Configuration
# Provider: openai | gemini | ollama
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEMPERATURE=0
OPENAI_MAX_TOKENS=1024

# Google Gemini
GEMINI_API_KEY=xxx
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0
GEMINI_MAX_TOKENS=1024

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TEMPERATURE=0