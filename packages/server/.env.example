# 环境配置
NODE_ENV=development
APP_NAME=account-server
PORT=3000
API_PREFIX=api/v1
APP_ORIGIN=http://localhost:3000

# 日志配置
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_IGNORED_PATHS=/health,/healthz,/metrics,/favicon.ico

# Database
DATABASE_URL=postgresql://admin:admin@localhost:5432/account?schema=public
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=account
