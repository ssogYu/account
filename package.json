{
  "name": "ai-account-book",
  "version": "0.1.0",
  "private": true,
  "description": "AI智能记账助手",
  "scripts": {
    "dev:server": "pnpm --filter @ai-account/server start:local",
    "dev:mobile": "pnpm --filter @ai-account/mobile start",
    "dev:desktop": "pnpm --filter @ai-account/desktop dev",
    "build:shared": "pnpm --filter @ai-account/shared build",
    "build:server": "pnpm --filter @ai-account/server build",
    "build:mobile": "pnpm --filter @ai-account/mobile build",
    "build:desktop": "pnpm --filter @ai-account/desktop build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild",
      "@prisma/client"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
