{
  "expo": {
    "name": "记账啦！宝儿",
    "slug": "ai-account-book",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "aiaccount",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.aiaccount.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.aiaccount.app"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
